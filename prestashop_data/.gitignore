############################
.env
.env.local
.env.*.local
config/settings.inc.php
config/parameters.php
app/config/parameters.php

############################
# CACHE & LOGS
############################
/var/cache/*
/var/logs/*
/var/sessions/*
!/var/cache/.gitkeep
!/var/logs/.gitkeep
!/var/sessions/.gitkeep

############################
